      },
      {
        "sourceTag": "text",
        "type": "custom",
        "children": [
          "Foundation: 10 pts  |  Tableau: 5 pts  |  Card flip: 5 pts"
        ],
        "properties": {
          "fontsize": "10",
          "color": "#cccccc",
          "width": "100%"
        },
        "dataUid": "uid-21"
      },
      {
        "sourceTag": "text",
